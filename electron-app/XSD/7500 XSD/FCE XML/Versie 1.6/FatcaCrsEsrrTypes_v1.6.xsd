	<!-- Benulux Reference Id -->
	<xsd:simpleType name="DutchKingdomRefId_Type">
		<xsd:annotation>
			<xsd:documentation xml:lang="en">ReferenceID used in the Kingdom of the Netherlands</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:maxLength value="200"/>
		</xsd:restriction>
	</xsd:simpleType>
