			<xsd:enumeration value="AW">
				<xsd:annotation>
					<xsd:documentation xml:lang="en">Aruba</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="BQ">
				<xsd:annotation>
					<xsd:documentation xml:lang="en">Bonaire, Sint Eustasius and Saba</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="CW">
				<xsd:annotation>
					<xsd:documentation xml:lang="en">Curacao</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="NL">
				<xsd:annotation>
					<xsd:documentation xml:lang="en">The Netherlands</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="SX">
				<xsd:annotation>
					<xsd:documentation xml:lang="en">Sint Maarten (Dutch part)</xsd:documentation>
