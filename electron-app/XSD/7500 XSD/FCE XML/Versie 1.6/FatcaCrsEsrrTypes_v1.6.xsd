<?xml version="1.0" encoding="UTF-8"?>
<!-- edited with XMLSpy v2013 sp1 (x64) (http://www.altova.com) by Belastingdienst (Belastingdienst) -->
<xsd:schema xmlns:sfa_ftc="urn:oecd:ties:fatcacrsesrrtypes:v1" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:stf="urn:oecd:ties:stf:v4" xmlns:sfa="urn:oecd:ties:stffatcatypes:v1" xmlns:iso="urn:oecd:ties:isofatcatypes:v1" targetNamespace="urn:oecd:ties:fatcacrsesrrtypes:v1" elementFormDefault="qualified" attributeFormDefault="unqualified" version="1.1">
	<xsd:import namespace="urn:oecd:ties:isofatcatypes:v1" schemaLocation="isofatcatypes_v1.0.xsd"/>
	<xsd:import namespace="urn:oecd:ties:stffatcatypes:v1" schemaLocation="stffatcatypes_v1.1.xsd"/>
	<xsd:import namespace="urn:oecd:ties:stf:v4" schemaLocation="oecdtypes_v4.1.xsd"/>
	<!-- Financial Institution Account Number  -->
	<xsd:simpleType name="AccountNumberType">
		<xsd:annotation>
			<xsd:documentation xml:lang="en">Account number type </xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="OECD601"/>
			<xsd:enumeration value="OECD602"/>
			<xsd:enumeration value="OECD603"/>
			<xsd:enumeration value="OECD604"/>
			<xsd:enumeration value="OECD605"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:complexType name="AccountNumber_Type">
		<xsd:annotation>
			<xsd:documentation xml:lang="en">Account number definition</xsd:documentation>
		</xsd:annotation>
		<xsd:simpleContent>
			<xsd:extension base="xsd:string">
				<xsd:attribute name="AccNumberType" type="sfa_ftc:AccountNumberType" use="optional"/>
				<xsd:attribute name="UndocumentedAccount" type="xsd:boolean" use="optional"/>
				<xsd:attribute name="ClosedAccount" type="xsd:boolean" use="optional"/>
				<xsd:attribute name="DormantAccount" type="xsd:boolean" use="optional"/>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
